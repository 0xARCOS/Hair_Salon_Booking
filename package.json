{
  "name": "irene-hair-salon",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:agenda": "turbo run dev --filter=agenda",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "build:agenda": "turbo run build --filter=agenda",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5"
  },
  "packageManager": "npm@10.8.2"
}
