# --- Supabase (obligatorio para reservas, login y panel) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- Avisos por email de nuevas solicitudes de cita (opcional, recomendado) ---
# Crea una cuenta gratuita en https://resend.com y genera una API key.
# Si dejas estas variables vacías, las reservas funcionan igual pero sin aviso.
RESEND_API_KEY=re_...
SALON_NOTIFICATION_EMAIL=salon@ejemplo.com
# Remitente del aviso. Sin dominio propio verificado, usa el de pruebas de Resend
# (solo podrá enviarse a la dirección con la que creaste la cuenta de Resend):
RESEND_FROM=Reservas Irene <onboarding@resend.dev>

# --- Google Calendar (pendiente / opcional) ---
# GOOGLE_CLIENT_EMAIL=servicio@proyecto.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GOOGLE_CALENDAR_ID=agenda@gmail.com
