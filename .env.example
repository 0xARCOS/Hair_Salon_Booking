# --- Supabase (obligatorio para reservas, login y panel) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Clave service-role (SOLO servidor, secreta). Necesaria para enviar las
# notificaciones push al staff (el servidor lee los tokens saltando RLS).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# --- Avisos por email de nuevas solicitudes de cita (opcional, recomendado) ---
# Crea una cuenta gratuita en https://resend.com y genera una API key.
# Si dejas estas variables vacías, las reservas funcionan igual pero sin aviso.
RESEND_API_KEY=re_...
SALON_NOTIFICATION_EMAIL=salon@ejemplo.com
# Remitente del aviso. Sin dominio propio verificado, usa el de pruebas de Resend
# (solo podrá enviarse a la dirección con la que creaste la cuenta de Resend):
RESEND_FROM=Reservas Irene <onboarding@resend.dev>

# --- Google Calendar (pendiente / opcional) ---
# GOOGLE_CLIENT_EMAIL=servicio@proyecto.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GOOGLE_CALENDAR_ID=agenda@gmail.com

# --- Notificaciones Push (Firebase Cloud Messaging) ---
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:...
NEXT_PUBLIC_FIREBASE_VAPID_KEY=B...
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
