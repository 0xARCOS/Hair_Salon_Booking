# --- Supabase (obligatorio: login de staff, citas y fichas de clientas) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- Opcional: URL canónica del deploy de la agenda ---
# Si se define, los emails de recuperación de contraseña siempre apuntan aquí
# (en vez de derivar el origen del header Host de la petición).
# NEXT_PUBLIC_SITE_URL=https://agenda-tu-salon.netlify.app

# --- Opcional: tracking de errores (Sentry) ---
# Crea un proyecto Next.js en sentry.io y pega aquí su DSN; sin esta variable
# el tracking queda desactivado por completo.
# NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
