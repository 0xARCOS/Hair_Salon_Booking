# --- Supabase (obligatorio: la web pública lee el listado de servicios) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- Opcional: tracking de errores (Sentry) ---
# Crea un proyecto Next.js en sentry.io y pega aquí su DSN; sin esta variable
# el tracking queda desactivado por completo.
# NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
